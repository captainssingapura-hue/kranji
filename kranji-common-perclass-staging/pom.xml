<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>io.github.captainssingapura-hue.yong.kranji</groupId>
        <artifactId>Kranji</artifactId>
        <version>1.0-SNAPSHOT</version>
    </parent>

    <artifactId>kranji-common-perclass-staging</artifactId>

    <!--
      Staging area for catalog-iterator-generated typed ComposedZi records.

      All .java files under src/main/java/kranji/common/perclass/staging/
      are AUTO-GENERATED by kranji.codegen.catalog.CatalogIteratorMain.
      They are intentionally kept separate from the hand-authored records
      in kranji-common-perclass so that:

        - Generation is mechanical: the iterator can rewrite this whole
          tree on each round without risking a hand-authored file.
        - On build failure, this module can be bisected mechanically
          (delete half the generated files, rebuild, recurse) until the
          single broken row is isolated.
        - Promotion is a separate, explicit ritual: when staged records
          stabilise they get manually moved into kranji-common-perclass.

      AllPerclassRecordsStaging.ALL exposes the staged records as a flat
      list. AllZiRecords.ALL combines hand-authored + staged into the
      single registry that downstream tests should consume.
    -->

    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencies>
        <dependency>
            <groupId>io.github.captainssingapura-hue.yong.kranji</groupId>
            <artifactId>kranji-core</artifactId>
            <version>${project.parent.version}</version>
        </dependency>
        <dependency>
            <groupId>io.github.captainssingapura-hue.yong.kranji</groupId>
            <artifactId>kranji-singulars</artifactId>
            <version>${project.parent.version}</version>
        </dependency>
        <dependency>
            <groupId>io.github.captainssingapura-hue.yong.kranji</groupId>
            <artifactId>kranji-common-perclass</artifactId>
            <version>${project.parent.version}</version>
        </dependency>
        <!-- Promoted records: staged records can reference promoted ones
             as components (one-way dependency, enforces stability layering). -->
        <dependency>
            <groupId>io.github.captainssingapura-hue.yong.kranji</groupId>
            <artifactId>kranji-common-perclass-promoted</artifactId>
            <version>${project.parent.version}</version>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>5.10.2</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

</project>
